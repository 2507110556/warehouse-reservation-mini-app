/* pages/payment/index.wxss */
.container {
  padding-bottom: 80px;
  background-color: #f5f5f5;
}

/* 订单信息 */
.order-info {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #eee;
  font-size: 13px;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #666;
}

.info-value {
  color: #333;
  font-weight: 500;
}

.info-value.amount {
  font-size: 16px;
  color: #ff6b35;
}

/* 支付方式 */
.payment-methods {
  background-color: #fff;
  padding: 16px 0;
  margin-bottom: 12px;
}

.section-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  padding: 0 16px;
  margin-bottom: 12px;
}

.method-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #eee;
  border-left: 3px solid transparent;
}

.method-item.active {
  background-color: rgba(255, 107, 53, 0.05);
  border-left-color: #ff6b35;
}

.method-left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
}

.method-icon {
  width: 40px;
  height: 40px;
  border-radius: 4px;
  background-color: #f5f5f5;
}

.method-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.method-name {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.method-desc {
  font-size: 12px;
  color: #999;
}

/* 单选按钮 */
.radio {
  width: 20px;
  height: 20px;
  border: 2px solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.method-item.active .radio {
  border-color: #ff6b35;
}

.radio-checked {
  width: 8px;
  height: 8px;
  background-color: #ff6b35;
  border-radius: 50%;
}

/* 提示信息 */
.tips {
  background-color: #fff;
  padding: 12px 16px;
  margin-bottom: 12px;
  border-left: 3px solid #ffb366;
  border-radius: 4px;
}

.tips-title {
  display: block;
  font-size: 13px;
  color: #333;
  font-weight: bold;
  margin-bottom: 8px;
}

.tips-content {
  display: block;
  font-size: 12px;
  color: #666;
  line-height: 1.6;
}

/* 底部支付 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background-color: #fff;
  border-top: 1px solid #eee;
}

.pay-btn {
  width: 100%;
  background-color: #ff6b35;
  color: #fff;
  padding: 12px;
  border: none;
  border-radius: 4px;
  font-size: 14px;
}

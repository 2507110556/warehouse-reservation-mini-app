<!--pages/orders/index.wxml-->
<view class="container">
  <!-- 筛选条件 -->
  <view class="filter-bar">
    <view class="filter-tabs">
      <view class="filter-tab {{currentStatus === 'all' ? 'active' : ''}}" bindtap="filterByStatus" data-status="all">
        全部
      </view>
      <view class="filter-tab {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="filterByStatus" data-status="pending">
        待付款
      </view>
      <view class="filter-tab {{currentStatus === 'paid' ? 'active' : ''}}" bindtap="filterByStatus" data-status="paid">
        已付款
      </view>
      <view class="filter-tab {{currentStatus === 'shipped' ? 'active' : ''}}" bindtap="filterByStatus" data-status="shipped">
        待取货
      </view>
      <view class="filter-tab {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="filterByStatus" data-status="completed">
        已完成
      </view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="orders-list" wx:if="{{orders.length > 0}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" bindtap="navigateToDetail" data-id="{{item.id}}">
        <view class="order-header">
          <view class="order-info-left">
            <text class="order-id">订单号: {{item.orderNo}}</text>
            <text class="order-date">{{item.createTime}}</text>
          </view>
          <view class="order-status" style="background-color: {{item.statusBgColor}}; color: {{item.statusColor}}">
            {{item.statusText}}
          </view>
        </view>
        <view class="order-items">
          <block wx:for="{{item.items}}" wx:key="id">
            <view class="order-item">
              <image src="{{item.image}}" class="item-image"></image>
              <view class="item-info" style="flex: 1">
                <text class="item-name">{{item.productName}}</text>
                <text class="item-specs" wx:if="{{item.specs}}">{{item.specs}}</text>
              </view>
              <view class="item-price-qty">
                <text class="item-price">¥{{item.price}}</text>
                <text class="item-qty">×{{item.quantity}}</text>
              </view>
            </view>
          </block>
        </view>
        <view class="order-footer">
          <view class="order-total">
            <text class="total-label">合计:</text>
            <text class="total-price">¥{{item.totalPrice}}</text>
          </view>
          <view class="order-actions">
            <button class="action-btn secondary" wx:if="{{item.status === 'pending'}}" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
            <button class="action-btn primary" bindtap="navigateToDetail" data-id="{{item.id}}">详情</button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 空态 -->
  <view class="empty-state" wx:else>
    <image src="/images/empty-orders.png" class="empty-icon"></image>
    <text class="empty-text">这里还没有订单</text>
    <button class="shop-btn" bindtap="navigateToHome">去购物</button>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <image class="loading-icon" src="/images/loading.gif"></image>
    <text>加载中...</text>
  </view>
</view>

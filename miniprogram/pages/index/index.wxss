/* pages/index/index.wxss */
.container {
  padding-bottom: 60px;
}

/* 搜索栏 */
.search-bar {
  background-color: #ff6b35;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20px;
  padding: 8px 12px;
  flex: 1;
  max-width: 300px;
}

.search-icon {
  width: 16px;
  height: 16px;
  margin-right: 8px;
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 13px;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 200px;
  margin-bottom: 12px;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷菜单 */
.menu-section {
  background-color: #fff;
  margin-bottom: 12px;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background-color: #eee;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

.menu-item {
  background-color: #fff;
  padding: 16px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.menu-item image {
  width: 32px;
  height: 32px;
  margin-bottom: 8px;
}

.menu-item text {
  font-size: 12px;
  color: #333;
}

/* 分区 */
.section {
  background-color: #fff;
  margin-bottom: 12px;
  padding: 12px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #eee;
}

.section-icon {
  width: 20px;
  height: 20px;
  margin-right: 8px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.more-link {
  display: flex;
  align-items: center;
  color: #999;
  font-size: 12px;
}

.more-link image {
  width: 12px;
  height: 12px;
  margin-left: 4px;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.product-card {
  background-color: #f9f9f9;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid #eee;
}

.product-image {
  width: 100%;
  height: 150px;
  object-fit: cover;
}

.product-info {
  padding: 8px;
}

.product-name {
  display: block;
  font-size: 13px;
  color: #333;
  font-weight: 500;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  display: block;
  font-size: 11px;
  color: #999;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: flex;
  align-items: center;
  gap: 4px;
}

.price {
  font-size: 14px;
  color: #ff6b35;
  font-weight: bold;
}

.old-price {
  font-size: 11px;
  color: #999;
  text-decoration: line-through;
}

/* 热销列表 */
.hot-list {
  display: flex;
  flex-direction: column;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #eee;
  position: relative;
}

.hot-item:last-child {
  border-bottom: none;
}

.rank-badge {
  background-color: #ff6b35;
  color: #fff;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: bold;
  margin-right: 8px;
}

.hot-image {
  width: 60px;
  height: 60px;
  border-radius: 4px;
  object-fit: cover;
  margin-right: 12px;
}

.hot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hot-name {
  font-size: 13px;
  color: #333;
  font-weight: 500;
  margin-bottom: 4px;
}

.hot-sales {
  font-size: 11px;
  color: #999;
}

.hot-price {
  font-size: 14px;
  color: #ff6b35;
  font-weight: bold;
  margin-left: 8px;
}

/* 分类滚动 */
.category-scroll {
  margin: 12px -12px -12px -12px;
  padding: 8px 12px;
  background-color: #f9f9f9;
}

.category-list {
  display: flex;
  white-space: nowrap;
  padding: 4px 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16px;
  padding: 4px;
}

.category-item image {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #fff;
  padding: 4px;
}

.category-item text {
  font-size: 12px;
  color: #333;
  margin-top: 4px;
}

/* 加载更多 */
.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
  color: #999;
}

.loading-icon {
  width: 20px;
  height: 20px;
  margin-bottom: 8px;
}

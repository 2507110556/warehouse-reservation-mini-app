<!--index.wxml-->
<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper" bindtap="navigateToSearch">
      <image src="/images/search.png" class="search-icon"></image>
      <input 
        class="search-input" 
        placeholder="搜索商品或仓库"
        disabled="true"
      />
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner" 
          indicator-dots="true" 
          autoplay="true" 
          interval="5000" 
          duration="500"
          circular="true">
    <block wx:for="{{banners}}" wx:key="id">
      <swiper-item>
        <image src="{{item.image}}" class="banner-image" bindtap="handleBannerTap" data-link="{{item.link}}"></image>
      </swiper-item>
    </block>
  </swiper>

  <!-- 快捷菜单 -->
  <view class="menu-section">
    <view class="menu-grid">
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/appointment/index">
        <image src="/images/appointment.png"></image>
        <text>我的预约</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/orders/index">
        <image src="/images/orders.png"></image>
        <text>我的订单</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/wallet/index">
        <image src="/images/wallet.png"></image>
        <text>我的钱包</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/coupons/index">
        <image src="/images/coupon.png"></image>
        <text>优惠券</text>
      </view>
    </view>
  </view>

  <!-- 推荐商品 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐商品</text>
      <view class="more-link" bindtap="navigateTo" data-url="/pages/category/index">
        <text>查看更多</text>
        <image src="/images/arrow-right.png"></image>
      </view>
    </view>

    <view class="product-grid">
      <block wx:for="{{recommendProducts}}" wx:key="id">
        <view class="product-card" bindtap="navigateToDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" class="product-image"></image>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-desc">{{item.description}}</text>
            <view class="product-price">
              <text class="price">¥{{item.price}}</text>
              <text class="old-price">¥{{item.oldPrice}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 热销排行 -->
  <view class="section">
    <view class="section-header">
      <image src="/images/fire.png" class="section-icon"></image>
      <text class="section-title">热销排行</text>
    </view>

    <view class="hot-list">
      <block wx:for="{{hotProducts}}" wx:key="id">
        <view class="hot-item" bindtap="navigateToDetail" data-id="{{item.id}}">
          <view class="rank-badge">{{index + 1}}</view>
          <image src="{{item.image}}" class="hot-image"></image>
          <view class="hot-info flex-1">
            <text class="hot-name">{{item.name}}</text>
            <text class="hot-sales">销量: {{item.sales}}</text>
          </view>
          <text class="hot-price">¥{{item.price}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 分类导航 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">商品分类</text>
    </view>
    <view class="category-scroll">
      <scroll-view scroll-x="true" class="category-list">
        <block wx:for="{{categories}}" wx:key="id">
          <view class="category-item" bindtap="filterByCategory" data-id="{{item.id}}">
            <image src="{{item.icon}}"></image>
            <text>{{item.name}}</text>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <image class="loading-icon" src="/images/loading.gif"></image>
    <text>加载中...</text>
  </view>
</view>

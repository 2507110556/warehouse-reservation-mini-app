/* pages/product-detail/index.wxss */
.container {
  padding-bottom: 120px;
}

/* 轮播图 */
.product-swiper {
  width: 100%;
  height: 400px;
}

.product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 产品信息区 */
.product-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.price {
  font-size: 28px;
  color: #ff6b35;
  font-weight: bold;
}

.old-price {
  font-size: 14px;
  color: #999;
  text-decoration: line-through;
}

.favorite-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn image {
  width: 24px;
  height: 24px;
}

.product-name {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  line-height: 1.4;
}

.product-desc {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12px;
}

/* 统计信息 */
.stats {
  display: flex;
  gap: 24px;
  padding: 12px 0;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.stat-value {
  font-size: 14px;
  color: #333;
  font-weight: bold;
}

/* 规格选择 */
.specs {
  margin-top: 12px;
}

.specs-title {
  display: block;
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}

.spec-group {
  margin-bottom: 16px;
}

.spec-name {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.spec-option {
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 13px;
  color: #666;
  background-color: #f9f9f9;
}

.spec-option.active {
  border-color: #ff6b35;
  background-color: rgba(255, 107, 53, 0.1);
  color: #ff6b35;
}

/* 数量选择 */
.quantity-section {
  margin-top: 16px;
  padding-top: 12px;
  border-top: 1px solid #eee;
}

.quantity-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.quantity-control {
  display: flex;
  align-items: center;
  width: fit-content;
  border: 1px solid #ddd;
  border-radius: 4px;
}

.qty-btn {
  width: 32px;
  height: 32px;
  padding: 0;
  border: none;
  background-color: transparent;
  color: #666;
  font-size: 16px;
}

.qty-btn:active {
  background-color: #f5f5f5;
}

.qty-btn:disabled {
  color: #ccc;
}

.qty-input {
  width: 50px;
  height: 32px;
  text-align: center;
  border: none;
  border-left: 1px solid #ddd;
  border-right: 1px solid #ddd;
  font-size: 14px;
}

/* 预约时间选择 */
.appointment-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.section-title {
  display: block;
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}

.date-picker {
  margin-bottom: 16px;
}

.date-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 4px;
  font-size: 14px;
  color: #333;
}

.date-input image {
  width: 16px;
  height: 16px;
}

.time-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.slots-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.time-slot {
  padding: 12px 8px;
  background-color: #f5f5f5;
  border: 1px solid #ddd;
  border-radius: 4px;
  text-align: center;
  font-size: 13px;
  color: #666;
  position: relative;
}

.time-slot.active {
  background-color: rgba(255, 107, 53, 0.1);
  border-color: #ff6b35;
  color: #ff6b35;
}

.time-slot.disabled {
  background-color: #f0f0f0;
  color: #ccc;
  cursor: not-allowed;
}

.slot-count {
  display: block;
  font-size: 11px;
  color: #999;
  margin-top: 4px;
}

/* 详情区 */
.detail-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.detail-section rich-text {
  font-size: 14px;
  line-height: 1.6;
  color: #666;
}

/* 评价区 */
.review-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.rating-avg {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rating-score {
  font-size: 18px;
  color: #ff6b35;
  font-weight: bold;
}

.rating-level {
  font-size: 12px;
  color: #999;
}

.reviews {
  margin-bottom: 12px;
}

.review-item {
  padding-bottom: 12px;
  margin-bottom: 12px;
  border-bottom: 1px solid #eee;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header-info {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 8px;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 13px;
  color: #333;
  margin-bottom: 4px;
}

.rating {
  display: flex;
  gap: 2px;
}

.rating image {
  width: 12px;
  height: 12px;
}

.review-time {
  font-size: 12px;
  color: #999;
}

.review-content {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8px;
}

.review-images {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.review-img {
  width: 60px;
  height: 60px;
  border-radius: 4px;
  object-fit: cover;
}

.more-reviews {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12px;
  color: #ff6b35;
  font-size: 13px;
}

.more-reviews image {
  width: 12px;
  height: 12px;
  margin-left: 4px;
}

/* 底部操作栏 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  border-top: 1px solid #eee;
  z-index: 100;
  padding: 0;
  height: 60px;
}

.action-left {
  display: flex;
  flex: 0 0 auto;
  gap: 0;
}

.service-btn,
.share-btn {
  width: 60px;
  height: 60px;
  padding: 0;
  border: none;
  background-color: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #333;
}

.service-btn image,
.share-btn image {
  width: 20px;
  height: 20px;
  margin-bottom: 2px;
}

.action-right {
  display: flex;
  flex: 1;
  gap: 0;
}

.add-cart-btn,
.buy-now-btn {
  flex: 1;
  padding: 0;
  border: none;
  height: 60px;
  font-size: 14px;
}

.add-cart-btn {
  background-color: #f5f5f5;
  color: #333;
}

.buy-now-btn {
  background-color: #ff6b35;
  color: #fff;
}

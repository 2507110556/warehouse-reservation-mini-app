/* pages/cart/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.cart-list {
  flex: 1;
  overflow-y: auto;
}

/* 购物车头部 */
.cart-header {
  background-color: #fff;
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-text {
  margin-left: 8px;
  font-size: 14px;
  color: #333;
}

checkbox {
  width: 18px;
  height: 18px;
}

.edit-btn {
  color: #ff6b35;
  font-size: 14px;
}

/* 购物车商品项 */
.cart-item {
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 12px 16px;
  margin-bottom: 1px;
  border-bottom: 1px solid #eee;
  position: relative;
}

.item-checkbox {
  margin-right: 12px;
}

.item-content {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 12px;
}

.item-image {
  width: 80px;
  height: 80px;
  border-radius: 4px;
  object-fit: cover;
  flex-shrink: 0;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.item-name {
  font-size: 14px;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-specs {
  font-size: 12px;
  color: #999;
}

.item-time {
  font-size: 12px;
  color: #666;
  background-color: #f5f5f5;
  padding: 4px 6px;
  border-radius: 2px;
  width: fit-content;
}

.item-price-qty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 12px;
  min-width: 80px;
}

.item-price {
  font-size: 14px;
  color: #ff6b35;
  font-weight: bold;
  margin-bottom: 8px;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 4px;
}

.qty-btn {
  width: 24px;
  height: 24px;
  padding: 0;
  border: none;
  background-color: transparent;
  color: #666;
  font-size: 14px;
}

.qty-input {
  width: 30px;
  height: 24px;
  text-align: center;
  border: none;
  border-left: 1px solid #ddd;
  border-right: 1px solid #ddd;
  font-size: 12px;
}

.qty-display {
  font-size: 14px;
  color: #666;
}

.delete-btn {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn image {
  width: 20px;
  height: 20px;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40px 20px;
}

.empty-icon {
  width: 120px;
  height: 120px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  color: #333;
  font-weight: bold;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #999;
  margin-bottom: 24px;
}

.shop-btn {
  background-color: #ff6b35;
  color: #fff;
  padding: 12px 32px;
  border-radius: 20px;
  border: none;
}

/* 底部结算栏 */
.cart-footer {
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-top: 1px solid #eee;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 4px;
}

.total-label {
  font-size: 14px;
  color: #666;
}

.total-price {
  font-size: 18px;
  color: #ff6b35;
  font-weight: bold;
}

.item-count {
  font-size: 12px;
  color: #999;
}

.footer-right {
  flex: 0 0 auto;
}

.settlement-btn {
  background-color: #ff6b35;
  color: #fff;
  padding: 12px 32px;
  border: none;
  border-radius: 4px;
  font-size: 14px;
}

.settlement-btn:disabled {
  background-color: #ccc;
  color: #fff;
}
